{
  "//": "Workspace 根级 IDE 配置：仅供 tsserver/编辑器解析跨包类型，不参与 package 构建。各包的 tsconfig.build.json 仍直接 extends ./tsconfig.base.json，不会继承这里的 paths，因此 build 行为不受影响。",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@imagen-ps/core-engine": ["packages/core-engine/src/index.ts"],
      "@imagen-ps/providers": ["packages/providers/src/index.ts"],
      "@imagen-ps/workflows": ["packages/workflows/src/index.ts"],
      "@imagen-ps/shared-commands": ["packages/shared-commands/src/index.ts"],
      "@imagen-ps/shared-commands/commands": ["packages/shared-commands/src/commands/index.ts"]
    }
  },
  "include": [
    "apps/*/src/**/*.ts",
    "apps/*/src/**/*.tsx",
    "apps/*/tests/**/*.ts",
    "apps/*/test/**/*.ts",
    "packages/*/src/**/*.ts",
    "packages/*/tests/**/*.ts",
    "packages/*/test/**/*.ts"
  ]
}
