{
  "$comment": "E2E smoke 测试配置（可提交，无密钥）。密钥仍放 .test.env，由 apiKeyEnv 按名引用。可用 IMAGEN_SMOKE_CONFIG 指向自定义配置文件。路径相对仓库根目录。",

  "output": { "count": 1, "width": 1024, "height": 1024 },

  "tasks": {
    "text_to_image": {
      "workflow": "provider-generate",
      "operation": "text_to_image",
      "prompt": "simple blue square icon on a plain white background"
    },
    "image_edit": {
      "workflow": "provider-edit",
      "operation": "image_edit",
      "prompt": "adjust the geometric shape to blue while keeping a plain white background",
      "source": "asset/test_source_512.png"
    },
    "image_edit_mask": {
      "workflow": "provider-edit",
      "operation": "image_edit",
      "prompt": "fill the transparent center region with a soft green geometric shape",
      "source": "asset/test_source_512.png",
      "mask": "asset/test_mask_512.png"
    }
  },

  "entries": [
    {
      "name": "mock",
      "providerId": "mock",
      "family": "image-endpoint",
      "baseURL": "https://mock.local",
      "model": "mock-image-v1",
      "apiKey": "mock-key",
      "live": false,
      "implemented": true,
      "required": true,
      "tasks": ["text_to_image", "image_edit", "image_edit_mask"]
    },
    {
      "name": "n1n",
      "providerId": "image-endpoint",
      "family": "image-endpoint",
      "baseURL": "https://llm-api.net",
      "baseURLEnv": "IMAGEN_SMOKE_N1N_BASE_URL",
      "model": "gpt-image-1.5",
      "modelEnv": "IMAGEN_SMOKE_N1N_MODEL",
      "apiKeyEnv": "IMAGEN_SMOKE_N1N_API_KEY",
      "live": true,
      "implemented": true,
      "required": true,
      "tasks": ["text_to_image", "image_edit", "image_edit_mask"],
      "output": { "quality": "low" }
    },
    {
      "name": "openrouter",
      "providerId": "chat-image",
      "family": "chat-image",
      "baseURL": "https://openrouter.ai/api/v1",
      "baseURLEnv": "IMAGEN_SMOKE_OPENROUTER_BASE_URL",
      "model": "sourceful/riverflow-v2.5-fast",
      "modelEnv": "IMAGEN_SMOKE_OPENROUTER_MODEL",
      "apiKeyEnv": "IMAGEN_SMOKE_OPENROUTER_API_KEY",
      "live": true,
      "implemented": true,
      "required": true,
      "tasks": ["text_to_image", "image_edit"],
      "output": { "count": 1, "width": 1024, "height": 1024 }
    }
  ]
}
