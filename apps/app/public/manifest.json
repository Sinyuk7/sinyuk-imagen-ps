{
  "manifestVersion": 5,
  "id": "com.imagen-ps.panel",
  "name": "Imagen PS",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "25.0.0"
  },
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "localFileSystem": "request"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "imagen-ps-panel",
      "label": {
        "default": "Imagen",
        "en": "Imagen",
        "zh": "Imagen"
      },
      "minimumSize": {
        "width": 320,
        "height": 480
      },
      "maximumSize": {
        "width": 720,
        "height": 960
      },
      "preferredDockedSize": {
        "width": 380,
        "height": 640
      },
      "preferredFloatingSize": {
        "width": 380,
        "height": 640
      }
    }
  ]
}
