{
  "manifestVersion": 5,
  "id": "com.imagen-ps.panel",
  "name": "Imagen PS",
  "version": "0.1.0",
  "main": "index.html",
  "host": {
    "app": "PS",
    "minVersion": "26.1.0"
  },
  "requiredPermissions": {
    "network": {
      "domains": "all"
    },
    "localFileSystem": "request",
    "clipboard": "readAndWrite"
  },
  "entrypoints": [
    {
      "type": "panel",
      "id": "imagen-ps-panel",
      "label": {
        "default": "Imagen",
        "en": "Imagen",
        "zh": "Imagen"
      },
      "minimumSize": {
        "width": 300,
        "height": 420
      },
      "preferredDockedSize": {
        "width": 360,
        "height": 600
      },
      "preferredFloatingSize": {
        "width": 420,
        "height": 680
      },
      "maximumSize": {
        "width": 2000,
        "height": 2000
      }
    }
  ]
}
