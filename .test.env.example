# Release test credentials template — safe to commit (no real keys).
# Copy to .test.env and fill in keys. .test.env is gitignored.
#
# 这些变量仅由 Release 真实接口测试读取，激活开关在命令行：
#   pnpm test:release        # 只跑 Release 测试
#   pnpm validate:release    # 先跑 pnpm validate，再跑 Release 测试
# Release runner 内部设置 IMAGEN_TEST_LEVEL=release，并从仓库根 .test.env 读取本文件列出的全部变量。
# 缺失 .test.env、缺失任一必需变量、或未发现任何 *.release.test.* 文件时，Release 命令立即失败（不静默 skip）。
# 错误信息只列变量名，绝不打印 key 或 Authorization header。
# 普通 `pnpm test` / `pnpm validate` 不读取本文件、不调用真实接口。

# n1n / llm-api.net
# The image-endpoint provider appends /v1/images/* and /v1/models itself.
# Asian default: https://llm-api.net
# Global alternative: https://api.n1n.ai
IMAGEN_SMOKE_N1N_API_KEY=
IMAGEN_SMOKE_N1N_BASE_URL=https://llm-api.net
IMAGEN_SMOKE_N1N_MODEL=gpt-image-1.5

# OpenRouter
IMAGEN_SMOKE_OPENROUTER_API_KEY=
IMAGEN_SMOKE_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
IMAGEN_SMOKE_OPENROUTER_MODEL=sourceful/riverflow-v2.5-fast

# Prompt Optimizer
# Must be an OpenAI-compatible chat/completions base URL.
# Example:
#   IMAGEN_SMOKE_PROMPT_OPTIMIZER_BASE_URL=https://llm-api.net/v1
IMAGEN_SMOKE_PROMPT_OPTIMIZER_API_KEY=
IMAGEN_SMOKE_PROMPT_OPTIMIZER_BASE_URL=
IMAGEN_SMOKE_PROMPT_OPTIMIZER_MODEL=gpt-4o-mini
