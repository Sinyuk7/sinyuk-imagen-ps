{
  "name": "sinyuk-imagen-ps",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "bootstrap": "pnpm install --frozen-lockfile && pnpm validate",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "check:policy": "node scripts/check-policy.mjs",
    "validate": "pnpm build && pnpm test && pnpm check:policy",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  }
}
